{
  "name": "bugfixer-agent",
  "version": "0.1.0",
  "description": "自动 Bug 诊断与修复工具 — 给 vibe coder 的智能调试助手",
  "type": "module",
  "bin": {
    "bugfixer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "debugging",
    "agent",
    "nextjs",
    "supabase",
    "vercel"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
